PORT=5001
NODE_ENV=development
MONGOOSE_URI=mongodb://127.0.0.1:27017/qlnhatro
JWT_SECRET=replace_with_your_jwt_secret

# SePay webhook auth (SePay -> your server)
SEPAY_API_KEY=replace_with_sepay_webhook_api_key

# SePay user API auth (your server -> SePay)
SEPAY_TOKEN=replace_with_sepay_bearer_token

# Payment code generation
SEPAY_PAYMENT_PREFIX=TRO
INVOICE_DUE_DAY=5

# Optional webhook rate limit
SEPAY_RATE_LIMIT_WINDOW_MS=60000
SEPAY_RATE_LIMIT_MAX=120

# Optional reconciliation schedule (minutes)
SEPAY_RECONCILE_INTERVAL_MINUTES=60
